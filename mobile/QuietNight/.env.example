# Backend API base URL (no trailing slash).
# Simulator/device and backend are on different hosts — use the machine running the backend.
# Example (backend on 192.168.1.68): http://192.168.1.68:8000
# - Same machine: http://localhost:8000
# - Android Emulator (backend on host): http://10.0.2.2:8000
EXPO_PUBLIC_API_URL=http://192.168.1.68:8000
