# QuietNight Backend — copy to .env and fill in values.
# See README for setup.

# --- Supabase (required for auth and DB) ---
SUPABASE_URL=
# If the secret contains + or =, wrap in double quotes: SUPABASE_JWT_SECRET="your-jwt-secret"
SUPABASE_JWT_SECRET=your-jwt-secret
# Required for auth.admin (e.g. get_user_by_id). Dashboard -> Settings -> API -> service_role
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
APP_ENV=development
PARTNER_CHECKIN_BASE_URL=https://quietnight.app/partner/checkin

# --- OpenAI (optional: journey best-remedy summary, night insights) ---
OPENAI_API_KEY=
